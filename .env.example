APP_ENV=dev

# ── Ledger ────────────────────────────────────────────────────────────────────
LEDGER_GRPC_PORT=50051

# Postgres — the app always reconstructs the DSN from individual vars;
# setting POSTGRES_URL alone has no effect.
POSTGRES_DB=postgres          # docker-compose container name — keep in sync with POSTGRES_NAME
POSTGRES_NAME=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_SSL_MODE=disable

# Authority public key for the Ledger (provide ONE of the two options).
# Run `make keygen` first — it writes .key/id_ed25519 and .key/id_ed25519.pub.hex.
AUTHORITY_PUB_KEY_PATH=.key/id_ed25519    # path to JSON keypair file; public key is extracted
AUTHORITY_PUB_KEY=                         # hex-encoded ed25519 pubkey; takes precedence if set

# ── Game Server ───────────────────────────────────────────────────────────────
GAME_SERVER_GRPC_PORT=50052
LEDGER_ADDR=localhost:50051
AUTHORITY_KEY_PATH=.key/id_ed25519        # full keypair (private + public) used to sign MINT txs
MISSION_COOLDOWN_SECONDS=300              # seconds a player must wait between mission completions

# Redis (used by Game Server for mission state & cooldown tracking)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Player CLI ────────────────────────────────────────────────────────────────
PLAYER_KEY_PATH=.key/player_ed25519       # auto-generated on first run if absent
SERVER_ADDR=localhost:50052

